        "name": "Authored",
        "from": "User",
        "to": "Post",
        "id_field": "authoredId",
        "id_type": "int",
        "fields": [
          {
            "name": "year",
            "type": "int",
            "required": true
          }
        ]
      }
    ]
  },
  "data": {
    "nodes": [
      {
        "id": 1,
        "model": "User",
        "props": {
          "age": 42,
          "name": "Alice"
        }
      },
      {
        "id": 2,
        "model": "Post",
        "props": {
          "title": "Hello"
        }
      }
    ],
    "edges": [
      {
        "id": 1,
        "model": "Authored",
        "from": 1,
        "to": 2,
        "props": {
          "year": 2024
        }
      }
    ]
  }
}
