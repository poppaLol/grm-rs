{
  "format": "grm.interchange",
  "version": 1,
  "kind": "graph",
  "identity": {
    "node": "int",
    "edge": "int"
  },
  "schema": {
    "nodes": [
      {
        "name": "Post",
        "id_field": "postId",
        "id_type": "int",
        "fields": [
          {
            "name": "title",
            "type": "string",
            "required": true
          }
        ]
      },
      {
        "name": "User",
        "id_field": "userId",
        "id_type": "int",
        "fields": [
          {
            "name": "name",
            "type": "string",
